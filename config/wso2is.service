[Unit]
Description=WSO2 Identity Server 7.3
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=wso2
Group=wso2
Environment=JAVA_HOME=/usr/lib/jvm/java-21-amazon-corretto
Environment=JVM_MEM_OPTS=-Xms2g -Xmx2g
ExecStart=/opt/wso2is/bin/wso2server.sh
# WSO2 handles SIGTERM as a graceful shutdown.
KillSignal=SIGTERM
TimeoutStopSec=120
Restart=on-failure
RestartSec=10
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
